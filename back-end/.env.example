NODE_ENV=development
PORT=8787

TURSO_DATABASE_URL=libsql://dbpos-grocery-oatapiwat.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=
DATABASE_URL=libsql://dbpos-grocery-oatapiwat.aws-ap-northeast-1.turso.io
PRISMA_DATABASE_URL=file:./dev.db

JWT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Base folder for all Cloudinary uploads. The product image service appends
# "/<storeId>/products" automatically for multi-tenant isolation.
CLOUDINARY_UPLOAD_FOLDER=pos-grocery

# Google Sheets sync (run via `npm run sync:sheets`)
# Public CSV export URL of a Google Sheet shared with "Anyone with the link".
# Use the /export?format=csv&gid=0 endpoint so we can read without auth.
GOOGLE_SHEETS_CSV_URL=

# Google Custom Search JSON API (optional, fallback for product image search)
# Create API key: https://console.cloud.google.com/apis/credentials
# Create Search Engine: https://programmablesearchengine.google.com/
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
